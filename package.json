{
  "name": "leniency",
  "version": "0.2.0",
  "private": true,
  "description": "A dependency-free Lenia-inspired browser playground.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "python -m http.server 5173 --bind 127.0.0.1",
    "test": "node --test tests/*.test.js",
    "check:syntax": "node scripts/check-syntax.js",
    "extract:lifeforms": "node scripts/extract-lenia-repository-lifeforms.js",
    "generate:lifeforms": "node scripts/generate-lifeform-images.js",
    "check": "npm run check:syntax && npm test"
  }
}
